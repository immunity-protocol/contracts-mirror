# RPC endpoints — used by foundry.toml's [rpc_endpoints] table.
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Block explorer API keys for `forge verify-contract`.
ETHERSCAN_API_KEY=YOUR_KEY
BASESCAN_API_KEY=YOUR_KEY

# Deployer key — must hold gas on every chain you broadcast to.
# Use `cast wallet new` if you need a fresh hot wallet for testnet.
DEPLOYER_PRIVATE_KEY=0x...

# Mirror constructor args.
# MIRROR_ADMIN: receives admin role; can rotate relayers later.
# MIRROR_INITIAL_RELAYER: the relayer's hot wallet (lives in immunity-app).
MIRROR_ADMIN=0x...
MIRROR_INITIAL_RELAYER=0x...

# Hook constructor args (set per chain from network.json).
POOL_MANAGER=0xE03A1074c86CFeDd5C142C4F04F1a1536e203543
MIRROR_ADDRESS=0x...
